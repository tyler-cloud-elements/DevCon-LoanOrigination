{
    "name": "@uipath/uipath-typescript",
    "version": "1.3.5",
    "description": "UiPath TypeScript SDK",
    "license": "MIT",
    "keywords": [
        "uipath",
        "typescript",
        "nodejs",
        "sdk",
        "automation",
        "agentic-ai"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.cjs"
            }
        },
        "./core": {
            "import": {
                "types": "./dist/core/index.d.ts",
                "default": "./dist/core/index.mjs"
            },
            "require": {
                "types": "./dist/core/index.d.ts",
                "default": "./dist/core/index.cjs"
            }
        },
        "./entities": {
            "import": {
                "types": "./dist/entities/index.d.ts",
                "default": "./dist/entities/index.mjs"
            },
            "require": {
                "types": "./dist/entities/index.d.ts",
                "default": "./dist/entities/index.cjs"
            }
        },
        "./tasks": {
            "import": {
                "types": "./dist/tasks/index.d.ts",
                "default": "./dist/tasks/index.mjs"
            },
            "require": {
                "types": "./dist/tasks/index.d.ts",
                "default": "./dist/tasks/index.cjs"
            }
        },
        "./assets": {
            "import": {
                "types": "./dist/assets/index.d.ts",
                "default": "./dist/assets/index.mjs"
            },
            "require": {
                "types": "./dist/assets/index.d.ts",
                "default": "./dist/assets/index.cjs"
            }
        },
        "./jobs": {
            "import": {
                "types": "./dist/jobs/index.d.ts",
                "default": "./dist/jobs/index.mjs"
            },
            "require": {
                "types": "./dist/jobs/index.d.ts",
                "default": "./dist/jobs/index.cjs"
            }
        },
        "./attachments": {
            "import": {
                "types": "./dist/attachments/index.d.ts",
                "default": "./dist/attachments/index.mjs"
            },
            "require": {
                "types": "./dist/attachments/index.d.ts",
                "default": "./dist/attachments/index.cjs"
            }
        },
        "./queues": {
            "import": {
                "types": "./dist/queues/index.d.ts",
                "default": "./dist/queues/index.mjs"
            },
            "require": {
                "types": "./dist/queues/index.d.ts",
                "default": "./dist/queues/index.cjs"
            }
        },
        "./buckets": {
            "import": {
                "types": "./dist/buckets/index.d.ts",
                "default": "./dist/buckets/index.mjs"
            },
            "require": {
                "types": "./dist/buckets/index.d.ts",
                "default": "./dist/buckets/index.cjs"
            }
        },
        "./processes": {
            "import": {
                "types": "./dist/processes/index.d.ts",
                "default": "./dist/processes/index.mjs"
            },
            "require": {
                "types": "./dist/processes/index.d.ts",
                "default": "./dist/processes/index.cjs"
            }
        },
        "./cases": {
            "import": {
                "types": "./dist/cases/index.d.ts",
                "default": "./dist/cases/index.mjs"
            },
            "require": {
                "types": "./dist/cases/index.d.ts",
                "default": "./dist/cases/index.cjs"
            }
        },
        "./maestro-processes": {
            "import": {
                "types": "./dist/maestro-processes/index.d.ts",
                "default": "./dist/maestro-processes/index.mjs"
            },
            "require": {
                "types": "./dist/maestro-processes/index.d.ts",
                "default": "./dist/maestro-processes/index.cjs"
            }
        },
        "./conversational-agent": {
            "import": {
                "types": "./dist/conversational-agent/index.d.ts",
                "default": "./dist/conversational-agent/index.mjs"
            },
            "require": {
                "types": "./dist/conversational-agent/index.d.ts",
                "default": "./dist/conversational-agent/index.cjs"
            }
        },
        "./feedback": {
            "import": {
                "types": "./dist/feedback/index.d.ts",
                "default": "./dist/feedback/index.mjs"
            },
            "require": {
                "types": "./dist/feedback/index.d.ts",
                "default": "./dist/feedback/index.cjs"
            }
        },
        "./document-understanding": {
            "import": {
                "types": "./dist/document-understanding/index.d.ts",
                "default": "./dist/document-understanding/index.mjs"
            },
            "require": {
                "types": "./dist/document-understanding/index.d.ts",
                "default": "./dist/document-understanding/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "prepack": "rimraf *.tgz",
        "prebuild": "rimraf dist",
        "build": "rollup -c",
        "build:watch": "rollup -c -w",
        "clean": "rimraf dist && rimraf node_modules && rimraf package-lock.json",
        "docs:api": "typedoc && npm run docs:post-process && npm run docs:coded-action-apps",
        "docs:coded-action-apps": "npm run docs --prefix packages/coded-action-apps",
        "docs:post-process": "node scripts/docs-post-process.mjs",
        "lint": "oxlint",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:unit": "vitest tests/unit",
        "test:integration": "vitest --config vitest.integration.config.ts",
        "test:integration:v0": "vitest --config vitest.integration.config.ts --testNamePattern='\\[v0\\]'",
        "test:integration:v1": "vitest --config vitest.integration.config.ts --testNamePattern='\\[v1\\]'",
        "test:integration:smoke": "vitest tests/integration/shared/smoke.integration.test.ts --config vitest.integration.config.ts",
        "test:integration:watch": "vitest --config vitest.integration.config.ts --watch",
        "test:all": "npm run test:unit && npm run test:integration",
        "test:watch": "vitest --watch",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "@opentelemetry/sdk-logs": "^0.204.0",
        "socket.io-client": "^4.8.1"
    },
    "peerDependencies": {
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@rollup/plugin-alias": "^6.0.0",
        "@rollup/plugin-commonjs": "^25.0.0",
        "@rollup/plugin-json": "^6.0.0",
        "@rollup/plugin-node-resolve": "^15.2.0",
        "@rollup/plugin-typescript": "^11.1.0",
        "@types/node": "^20.11.19",
        "@types/uuid": "^9.0.8",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "builtin-modules": "^3.3.0",
        "dotenv": "^17.2.0",
        "oxlint": "^1.43.0",
        "rimraf": "^6.0.1",
        "rollup": "^4.60.2",
        "rollup-plugin-dts": "^6.1.0",
        "tslib": "^2.8.1",
        "typedoc": "^0.28.13",
        "typedoc-plugin-markdown": "^4.8.1",
        "typescript": "^5.3.3",
        "vitest": "^3.2.4"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/UiPath/uipath-typescript.git"
    },
    "workspaces": [
        "packages/*"
    ]
}
